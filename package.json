{
  "name": "atlas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "campaign:dry-run": "bun services/workers/src/campaign-dry-run.ts",
    "campaign:launch": "bun services/workers/src/campaign-launch.ts",
    "campaign:activate-funded": "bun services/workers/src/campaign-activate-funded.ts",
    "campaign:ingest-reward-set": "bun services/workers/src/campaign-ingest-reward-set.ts",
    "campaign:init-lifecycle": "bun services/workers/src/campaign-init-lifecycle.ts",
    "campaign:synthesize": "bun services/workers/src/campaign-synthesize.ts",
    "lifecycle:check": "bun services/workers/src/lifecycle-check.ts",
    "reputation:update": "bun services/workers/src/reputation-update.ts",
    "runtime": "bun services/runtime/src/index.ts",
    "runtime:server": "bun services/runtime/src/server/index.ts",
    "tick": "bun services/workers/src/atlas-tick.ts",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@0xsplits/splits-sdk": "^6.5.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "viem": "^2.50.4"
