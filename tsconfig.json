{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "packages/**/*.ts",
    "services/**/*.ts",
    "apps/**/*.ts"
  ],
  "exclude": [
    "services/cf-worker/**"
  ]
}

